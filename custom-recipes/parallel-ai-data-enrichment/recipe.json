{
    "meta": {
        "label": "Parallel Web Enrichment",
        "description": "Enrich dataset rows using Parallel Web Systems Task API",
        "icon": "icon-globe"
    },

    "kind": "PYTHON",

    "inputRoles": [
        {
            "name": "input_dataset",
            "label": "Input Dataset",
            "description": "Dataset containing rows to enrich",
            "arity": "UNARY",
            "required": true,
            "acceptsDataset": true
        }
    ],

    "outputRoles": [
        {
            "name": "output_dataset",
            "label": "Output Dataset",
            "description": "Dataset with enriched data",
            "arity": "UNARY",
            "required": true,
            "acceptsDataset": true
        }
    ],

    "params": [
        {
            "name": "separator_api",
            "label": "API Configuration",
            "type": "SEPARATOR"
        },
        {
            "name": "api_key_preset",
            "label": "API Key",
            "description": "Parallel API key for authentication",
            "type": "PRESET",
            "parameterSetId": "parallel-api-key",
            "mandatory": true
        },
        {
            "name": "processor",
            "label": "Processor",
            "description": "Processor to use for task execution",
            "type": "SELECT",
            "selectChoices": [
                {
                    "value": "core",
                    "label": "Core"
                },
                {
                    "value": "base",
                    "label": "Base"
                },
                {
                    "value": "fast",
                    "label": "Fast"
                }
            ],
            "defaultValue": "base",
            "mandatory": true
        },
        {
            "name": "separator_input",
            "label": "Input Configuration",
            "type": "SEPARATOR"
        },
        {
            "name": "input_columns",
            "label": "Input Columns",
            "description": "Select columns to use as input for enrichment",
            "type": "COLUMNS",
            "columnRole": "input_dataset",
            "allowedColumnTypes": ["string", "int", "bigint", "float", "double"],
            "mandatory": true
        },
        {
            "name": "separator_output",
            "label": "Output Configuration",
            "type": "SEPARATOR"
        },
        {
            "name": "output_fields",
            "label": "Output Fields",
            "description": "Define the fields to extract from web sources",
            "type": "OBJECT_LIST",
            "mandatory": true,
            "subParams": [
                {
                    "name": "name",
                    "label": "Column name",
                    "type": "STRING",
                    "mandatory": true
                },
                {
                    "name": "type",
                    "label": "Type",
                    "type": "SELECT",
                    "mandatory": true,
                    "defaultValue": "string",
                    "selectChoices": [
                        {
                            "value": "string",
                            "label": "string"
                        },
                        {
                            "value": "int",
                            "label": "int"
                        },
                        {
                            "value": "float",
                            "label": "float"
                        },
                        {
                            "value": "bool",
                            "label": "bool"
                        }
                    ]
                },
                {
                    "name": "description",
                    "label": "Description",
                    "type": "STRING",
                    "mandatory": true
                }
            ]
        },
        {
            "name": "separator_advanced",
            "label": "Advanced Settings",
            "type": "SEPARATOR"
        },
        {
            "name": "max_wait_seconds",
            "label": "Max Wait Time (seconds)",
            "description": "Maximum time to wait for each task to complete",
            "type": "INT",
            "defaultValue": 300,
            "mandatory": true
        },
        {
            "name": "poll_interval_seconds",
            "label": "Poll Interval (seconds)",
            "description": "Time between status checks",
            "type": "INT",
            "defaultValue": 2,
            "mandatory": true
        },
        {
            "name": "batch_size",
            "label": "Batch Size",
            "description": "Number of rows to process before writing (0 = all at once)",
            "type": "INT",
            "defaultValue": 100,
            "mandatory": false
        },
        {
            "name": "continue_on_error",
            "label": "Continue on Error",
            "description": "Continue processing if a row fails (failed rows will have empty enrichment values)",
            "type": "BOOLEAN",
            "defaultValue": true,
            "mandatory": false
        }
    ],

    "resourceKeys": []
}
